{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bomberman Client-to-Server Messages",
  "oneOf": [
    { "$ref": "#/$defs/JOIN" },
    { "$ref": "#/$defs/INPUT" },
    { "$ref": "#/$defs/PING" },
    { "$ref": "#/$defs/LEAVE" }
  ],
  "$defs": {
    "JOIN": {
      "type": "object",
      "description": "Request a player slot when first connecting.",
      "properties": {
        "TYPE": { "const": "JOIN" }
      },
      "required": ["TYPE"],
      "additionalProperties": false
    },
    "INPUT": {
      "type": "object",
      "description": "Per-tick movement and bomb input. DX/DY are -1, 0, or 1 (direction). DROP_BOMB triggers planting at the player's grid tile.",
      "properties": {
        "DX": { "type": "integer", "enum": [-1, 0, 1], "description": "Horizontal direction" },
        "DY": { "type": "integer", "enum": [-1, 0, 1], "description": "Vertical direction" },
        "DROP_BOMB": { "type": "boolean", "description": "Whether to plant a bomb this tick" },
        "TICK": { "type": "integer", "description": "Target tick for this input" }
      },
      "required": ["DX", "DY", "DROP_BOMB", "TICK"],
      "additionalProperties": false
    },
    "PING": {
      "type": "object",
      "description": "Latency probe. Server echoes the ID back as a PONG.",
      "properties": {
        "TYPE": { "const": "PING" },
        "ID": { "type": "integer", "description": "Timestamp used to compute RTT" }
      },
      "required": ["TYPE", "ID"],
      "additionalProperties": false
    },
    "LEAVE": {
      "type": "object",
      "description": "Client disconnect. Also sent by the Go gateway on WebSocket/WebRTC close.",
      "properties": {
        "TYPE": { "const": "LEAVE" }
      },
      "required": ["TYPE"],
      "additionalProperties": false
    }
  }
}
