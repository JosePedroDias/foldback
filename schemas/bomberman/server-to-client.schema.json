{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bomberman Server-to-Client Messages",
  "oneOf": [
    { "$ref": "#/$defs/WELCOME" },
    { "$ref": "#/$defs/PONG" },
    { "$ref": "#/$defs/STATE_UPDATE" }
  ],
  "$defs": {
    "WELCOME": {
      "type": "object",
      "description": "Sent once after a successful JOIN. Assigns the player their ID.",
      "properties": {
        "YOUR_ID": { "type": "integer", "description": "Assigned player ID" },
        "GAME_ID": { "const": "bomberman" },
        "TICK_RATE": { "type": "integer", "description": "Server tick rate in Hz" }
      },
      "required": ["YOUR_ID", "GAME_ID", "TICK_RATE"],
      "additionalProperties": false
    },
    "PONG": {
      "type": "object",
      "description": "Echoes the ping ID back so the client can compute RTT.",
      "properties": {
        "PONG": { "type": "integer", "description": "The ID from the client's PING message" }
      },
      "required": ["PONG"],
      "additionalProperties": false
    },
    "STATE_UPDATE": {
      "type": "object",
      "description": "Game state snapshot, sent every tick.",
      "properties": {
        "TICK": { "type": "integer", "description": "Current server tick" },
        "SEED": { "type": "integer", "description": "Deterministic RNG seed for bot logic" },
        "PLAYERS": {
          "type": "array",
          "items": { "$ref": "#/$defs/PLAYER" },
          "description": "All players in the game"
        },
        "LEVEL": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "description": "2D tile grid (0=empty, 1=wall, 2=crate). Only sent when changed."
        },
        "BOMBS": {
          "type": "array",
          "items": { "$ref": "#/$defs/BOMB" },
          "description": "Active bombs on the map"
        },
        "EXPLOSIONS": {
          "type": "array",
          "items": { "$ref": "#/$defs/EXPLOSION" },
          "description": "Active explosion tiles"
        },
        "BOTS": {
          "type": "array",
          "items": { "$ref": "#/$defs/BOT" },
          "description": "AI-controlled bots"
        }
      },
      "required": ["TICK", "SEED"],
      "additionalProperties": false
    },
    "PLAYER": {
      "type": "object",
      "description": "Player state. Positions are fixed-point scale 1000.",
      "properties": {
        "ID": { "type": "integer", "description": "Player ID" },
        "X": { "type": "integer", "description": "X position (FP 1000)" },
        "Y": { "type": "integer", "description": "Y position (FP 1000)" },
        "HEALTH": { "type": "integer", "description": "Health (100 = alive, 0 = dead)" }
      },
      "required": ["ID", "X", "Y", "HEALTH"],
      "additionalProperties": false
    },
    "BOMB": {
      "type": "object",
      "description": "Bomb state. X/Y are integer grid coordinates.",
      "properties": {
        "X": { "type": "integer", "description": "Grid X position" },
        "Y": { "type": "integer", "description": "Grid Y position" },
        "TIMER": { "type": "integer", "description": "Ticks until detonation" }
      },
      "required": ["X", "Y", "TIMER"],
      "additionalProperties": false
    },
    "EXPLOSION": {
      "type": "object",
      "description": "Explosion tile. X/Y are integer grid coordinates.",
      "properties": {
        "X": { "type": "integer", "description": "Grid X position" },
        "Y": { "type": "integer", "description": "Grid Y position" }
      },
      "required": ["X", "Y"],
      "additionalProperties": false
    },
    "BOT": {
      "type": "object",
      "description": "Bot state. Positions are fixed-point scale 1000.",
      "properties": {
        "X": { "type": "integer", "description": "X position (FP 1000)" },
        "Y": { "type": "integer", "description": "Y position (FP 1000)" }
      },
      "required": ["X", "Y"],
      "additionalProperties": false
    }
  }
}
